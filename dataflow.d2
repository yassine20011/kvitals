direction: right

ksystemstats: "KDE System Stats Daemon\n(ksystemstats)" {
  shape: cylinder
  style.fill: "#353b48"
  style.font-color: "#dfe6e9"
  style.stroke: "#636e72"

  api: "D-Bus API\n(org.kde.ksysguard.sensors)" {
    shape: rectangle
    style.fill: "#0984e3"
    style.font-color: "#fff"
    style.border-radius: 4
  }
}

widget: "KVitals Widget\n(main.qml)" {
  shape: rectangle
  style.fill: "#2d3436"
  style.font-color: "#dfe6e9"
  style.stroke: "#636e72"
  style.border-radius: 8

  sensors: "Sensors.Sensor\n(Declarative Objects)" {
    style.fill: "#6c5ce7"
    style.font-color: "#fff"
  }

  compact: "Panel View\n(RowLayout + Repeater)" {
    style.fill: "#fd79a8"
    style.font-color: "#fff"
  }

  popup: "Popup View\n(ColumnLayout)" {
    style.fill: "#fd79a8"
    style.font-color: "#fff"
  }

  ttip: "Tooltip" {
    style.fill: "#fd79a8"
    style.font-color: "#fff"
  }

  sensors -> compact
  sensors -> popup
  sensors -> ttip
}

ksystemstats.api -> widget.sensors: "Live Data Streams"

plasmoid_config: "Plasmoid.configuration" {
  shape: cylinder
  style.fill: "#636e72"
  style.font-color: "#dfe6e9"
}

plasmoid_config -> widget.compact: "UI Preferences\n(displayMode, etc.)"
plasmoid_config -> widget.sensors: "updateRateLimit"
